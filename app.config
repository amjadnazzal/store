<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <appSettings>
        <!-- إعدادات قاعدة البيانات -->
        <add key="DatabasePath" value="ClothingStore.db" />
        
        <!-- إعدادات النسخ الاحتياطي -->
        <add key="BackupPath" value="Backups" />
        <add key="AutoBackup" value="true" />
        <add key="BackupIntervalDays" value="7" />
        
        <!-- إعدادات التنبيهات -->
        <add key="LowStockThreshold" value="5" />
        <add key="ShowLowStockAlerts" value="true" />
        
        <!-- إعدادات الطباعة -->
        <add key="DefaultPrinter" value="" />
        <add key="AutoPrintReceipts" value="false" />
        
        <!-- إعدادات الواجهة -->
        <add key="Language" value="ar" />
        <add key="Theme" value="Default" />
        
        <!-- إعدادات المتجر -->
        <add key="StoreName" value="متجر الملابس" />
        <add key="StoreAddress" value="" />
        <add key="StorePhone" value="" />
        <add key="StoreEmail" value="" />
    </appSettings>
    
    <connectionStrings>
        <add name="DefaultConnection" 
             connectionString="Data Source=ClothingStore.db;Version=3;" 
             providerName="System.Data.SQLite" />
    </connectionStrings>
</configuration>